<!DOCTYPE html>
<html lang="en">

    <head>

        <meta charset="UTF-8">

        <meta name="viewport"content="width=device-width, initial-scale=1.0">

        <title>Dashboard | Student Management System</title>

        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"rel="stylesheet">

        <!-- Font Awesome -->
        <link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

        <!-- Custom CSS -->
        <link rel="stylesheet"href="/css/style.css">

    </head>

    <body>
    
        <%- include("partials/navbar") %>

        <%- include("partials/alerts") %>

        <main class="container py-5">

            <div class="mb-4">

                <h2 class="fw-bold">Welcome Back, <%= username %> 👋</h2>

                <p class="text-muted">Here's a quick overview of your Student Management System.</p>
            
            </div>

            <div class="row g-4">

                <!-- Total Students -->

                <div class="col-md-4">

                    <div class="card dashboard-card text-center p-4 h-100">

                        <div class="dashboard-icon text-primary">

                            <i class="fa-solid fa-user-graduate"></i>

                        </div>

                        <h5>Total Students</h5>

                        <h1 class="text-primary"><%= total %></h1>

                    </div>

                </div>

                <!-- Database -->

                <div class="col-md-4">

                    <div class="card dashboard-card text-center p-4 h-100">

                        <div class="dashboard-icon text-success">

                            <i class="fa-solid fa-database"></i>

                        </div>

                        <h5>Database</h5>

                        <h4 class="text-success">Connected</h4>

                    </div>

                </div>

                <!-- Logged In User -->

                <div class="col-md-4">

                    <div class="card dashboard-card text-center p-4 h-100">

                        <div class="dashboard-icon text-warning">

                            <i class="fa-solid fa-user-shield"></i>

                        </div>

                        <h5>Logged In As</h5>

                        <h4><%= username %></h4>

                    </div>

                </div>

            </div>

            <!-- Quick Actions -->

            <div class="card mt-5 shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">Quick Actions</h5>

                </div>

                <div class="card-body">

                    <div class="d-flex flex-wrap gap-3">

                        <a href="/students"class="btn btn-primary">

                            <i class="fa-solid fa-users me-2"></i>

                            View Students

                        </a>

                        <a href="/add"class="btn btn-success">

                            <i class="fa-solid fa-user-plus me-2"></i>

                            Add Student

                        </a>

                        <a href="/logout"class="btn btn-danger">

                            <i class="fa-solid fa-right-from-bracket me-2"></i>

                            Logout

                        </a>

                    </div>

                </div>

            </div>

        </main>

        <%- include("partials/footer") %>

    </body>

</html>