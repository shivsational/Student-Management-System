<!DOCTYPE html>
<html lang="en">

    <head>
        
        <meta charset="UTF-8">
        
        <meta name="viewport"content="width=device-width, initial-scale=1.0">

        <title>Add Student | Student Management System</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"rel="stylesheet">
        
        <link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
        
        <link rel="stylesheet"href="/css/style.css">
        
    </head>

    <body>
        
        <%- include("partials/navbar") %>
        
        <%- include("partials/alerts") %>
        
        <main class="container py-5">
        
            <div class="row justify-content-center">
            
                <div class="col-lg-8">
                
                    <div class="card shadow border-0">
                    
                        <div class="card-header bg-success text-white">
                        
                            <h3 class="mb-1">
                            
                                <i class="fa-solid fa-user-plus me-2"></i>
                            
                                Add New Student
                            
                            </h3>
                        
                            <small>Fill in all required fields to add a new student.</small>
                        
                        </div>
                    
                        <div class="card-body p-4">
                        
                            <form action="/add" method="POST">
                            
                                <div class="row">
                                
                                    <div class="col-md-6 mb-3">
                                    
                                        <label class="form-label">
                                        
                                            <i class="fa-solid fa-user text-primary me-2"></i>
                                        
                                            Full Name
                                        
                                        </label>
                                    
                                        <input
                                            type="text"
                                            name="name"
                                            class="form-control"
                                            placeholder="Enter student name"
                                            autocomplete="off"
                                            required>
                                    
                                    </div>
                                
                                    <div class="col-md-6 mb-3">
                                    
                                        <label class="form-label">
                                        
                                            <i class="fa-solid fa-id-card text-primary me-2"></i>
                                        
                                            Roll Number
                                        
                                        </label>
                                    
                                        <input
                                            type="text"
                                            name="rollNo"
                                            class="form-control"
                                            placeholder="Enter roll number"
                                            autocomplete="off"
                                            required>
                                    
                                    </div>
                                
                                    <div class="col-md-6 mb-3">
                                    
                                        <label class="form-label">
                                        
                                            <i class="fa-solid fa-book text-primary me-2"></i>
                                        
                                            Course
                                        
                                        </label>
                                    
                                        <select
                                            name="course"
                                            class="form-select"
                                            required>
                                    
                                            <option value="">Select Course</option>
                                    
                                            <option>B.Tech CSE</option>
                                    
                                            <option>B.Tech AI</option>
                                    
                                            <option>B.Tech IT</option>
                                    
                                            <option>BCA</option>
                                    
                                            <option>B.Com</option>
                                    
                                            <option>BBA</option>
                                    
                                            <option>MCA</option>
                                    
                                            <option>M.Tech</option>
                                    
                                        </select>
                                    
                                    </div>
                                
                                    <div class="col-md-6 mb-3">
                                    
                                        <label class="form-label">
                                        
                                            <i class="fa-solid fa-envelope text-primary me-2"></i>
                                        
                                            Email
                                        
                                        </label>
                                    
                                        <input
                                            type="email"
                                            name="email"
                                            class="form-control"
                                            placeholder="Enter email"
                                            autocomplete="off"
                                            required>
                                    
                                    </div>
                                
                                    <div class="col-md-6 mb-4">
                                    
                                        <label class="form-label">
                                        
                                            <i class="fa-solid fa-phone text-primary me-2"></i>
                                        
                                            Phone Number
                                        
                                        </label>
                                    
                                        <input
                                            type="tel"
                                            name="phone"
                                            class="form-control"
                                            maxlength="10"
                                            pattern="[0-9]{10}"
                                            placeholder="9876543210"
                                            autocomplete="off"
                                            required>
                                    
                                    </div>
                                
                                </div>
                            
                                <div class="d-flex justify-content-between mt-3">

                                    <a href="/students"class="btn btn-outline-secondary">
                                
                                        <i class="fa-solid fa-arrow-left me-2"></i>

                                        Back to Students

                                    </a>

                                    <div>

                                        <a href="/students"class="btn btn-secondary me-2">Cancel</a>
                                    
                                        <button
                                            type="submit"
                                            class="btn btn-success">

                                            <i class="fa-solid fa-floppy-disk me-2"></i>

                                            Save Student

                                        </button>

                                    </div>

                                </div>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </main>

        <%- include("partials/footer") %>

    </body>

    </html>