<!DOCTYPE html>
<html lang="en">
    <head>

        <meta charset="UTF-8">

        <meta name="viewport"
              content="width=device-width, initial-scale=1.0">

        <title>404 | Page Not Found</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
              rel="stylesheet">

        <link rel="stylesheet"
              href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

        <link rel="stylesheet"
              href="/css/style.css">

    </head>

    <body>

        <main class="container">
        
            <div class="row justify-content-center align-items-center"
                 style="min-height:85vh;">
        
                <div class="col-lg-7">
                
                    <div class="card shadow text-center">
                    
                        <div class="card-body p-5">
                        
                            <i class="fa-solid fa-triangle-exclamation text-warning"style="font-size:90px;"></i>
                        
                            <h1 class="display-1 fw-bold mt-4">404</h1>
                        
                            <h3 class="mb-3">Page Not Found</h3>
                        
                            <p class="text-muted">Sorry! The page you're looking for doesn't existor may have been moved.</p>
                        
                            <a href="/dashboard"class="btn btn-primary mt-3">
                        
                                <i class="fa-solid fa-house me-2"></i>
                        
                                Back to Dashboard
                        
                            </a>
                        
                        </div>

                    </div>

                </div>

            </div>

        </main>

        <%- include("partials/footer") %>

    </body>
</html>